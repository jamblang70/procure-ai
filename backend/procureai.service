[Unit]
Description=ProcureAI Backend API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/procureai
EnvironmentFile=/opt/procureai/.env
ExecStart=/opt/procureai/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8899
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
